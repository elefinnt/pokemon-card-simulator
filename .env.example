# Pokémon TCG API key.
# Optional, but strongly recommended: without a key you are limited to
# 1,000 requests/day (30/min). With a free key the limit is 20,000/day.
# Register for a free key at https://dev.pokemontcg.io/
POKEMONTCG_API_KEY=your_key_here

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=your_secret_here

# Discord OAuth — create an app at https://discord.com/developers/applications
# Redirect URL: http://localhost:3000/api/auth/callback/discord
AUTH_DISCORD_ID=your_discord_client_id
AUTH_DISCORD_SECRET=your_discord_client_secret

# Railway MySQL connection string
# DATABASE_URL=mysql://user:password@host:port/database
